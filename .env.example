# Kerpta — Variables d'environnement
# 1. Copier : cp .env.example .env
# 2. Remplir SECRET_KEY et POSTGRES_PASSWORD au minimum
# 3. Lancer : docker compose up --build
# 4. Ouvrir  : http://localhost:3000  → wizard d'installation (/setup)
#
# NE JAMAIS committer .env

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=                          # openssl rand -hex 32  ← OBLIGATOIRE
DEBUG=true

# ─── URLs publiques ───────────────────────────────────────────────────────────
# Configurées aussi via le wizard /setup/oauth
APP_BASE_URL=http://localhost:3000
AUTH_BASE_URL=http://localhost:9999

# ─── Base de données ──────────────────────────────────────────────────────────
# Configurée via le wizard /setup/dbb — ces valeurs sont utilisées par Docker
POSTGRES_DB=kerpta
POSTGRES_USER=kerpta
POSTGRES_PASSWORD=kerpta_dev         # mot de passe fort en production !
# DATABASE_URL est construite automatiquement par docker-compose
# mais peut être surchargée ici si la DB est externe :
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/kerpta

# ─── Supabase Auth (GoTrue self-hosted) ───────────────────────────────────────
# Configuré via le wizard /setup/oauth
SUPABASE_JWT_SECRET=                 # openssl rand -hex 32 — OBLIGATOIRE en prod
# Même valeur transmise à GoTrue :
GOTRUE_JWT_SECRET=                   # = SUPABASE_JWT_SECRET

# Email/password désactivé — OAuth uniquement
GOTRUE_EXTERNAL_EMAIL_ENABLED=false
GOTRUE_DISABLE_SIGNUP=false

# Providers OAuth — configurés automatiquement par le wizard /setup/oauth
# Google — https://console.cloud.google.com
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=

# Microsoft — https://portal.azure.com
GOTRUE_EXTERNAL_AZURE_ENABLED=false
GOTRUE_EXTERNAL_AZURE_CLIENT_ID=
GOTRUE_EXTERNAL_AZURE_SECRET=

# Apple — https://developer.apple.com
GOTRUE_EXTERNAL_APPLE_ENABLED=false
GOTRUE_EXTERNAL_APPLE_CLIENT_ID=
GOTRUE_EXTERNAL_APPLE_SECRET=

# GitHub — https://github.com/settings/developers
GOTRUE_EXTERNAL_GITHUB_ENABLED=false
GOTRUE_EXTERNAL_GITHUB_CLIENT_ID=
GOTRUE_EXTERNAL_GITHUB_SECRET=

# ─── Chiffrement storage ───────────────────────────────────────────────────────
STORAGE_ENCRYPTION_KEY=              # openssl rand -hex 32

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@kerpta.fr

# ─── OCR (Mindee) — optionnel ─────────────────────────────────────────────────
MINDEE_API_KEY=

# ─── Signature électronique (DocuSeal) — optionnel ────────────────────────────
DOCUSEAL_API_KEY=
DOCUSEAL_API_URL=http://docuseal:3000
DOCUSEAL_SECRET_KEY=
DOCUSEAL_WEBHOOK_SECRET=

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
